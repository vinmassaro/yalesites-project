{
  "name": "yalesites-org/yalesites_profile",
  "type": "drupal-custom-profile",
  "repositories": [
    {
      "type": "composer",
      "url": "https://packages.drupal.org/8"
    }
  ],
  "require": {
    "drupal/address": "1.11.0",
    "drupal/admin_toolbar": "3.4.0",
    "drupal/allowed_formats": "2.0.0",
    "drupal/autosave_form": "1.4.0",
    "drupal/captcha": "1.10.0",
    "drupal/cas": "2.1.0",
    "drupal/chosen": "3.0.5",
    "drupal/components": "3.0.0-beta3",
    "drupal/config_ignore": "3.0.0-beta2",
    "drupal/config_split": "1.9.0",
    "drupal/ctools": "3.13.0",
    "drupal/devel": "5.1.1",
    "drupal/devel_kint_extras": "1.1.0",
    "drupal/easy_breadcrumb": "2.0.5",
    "drupal/editoria11y": "2.0.12",
    "drupal/emulsify_twig": "4.0.0",
    "drupal/entity_redirect": "2.2.0",
    "drupal/fast_404": "2.0.0-alpha6",
    "drupal/field_group": "3.4.0",
    "drupal/gin": "3.0.0-rc3",
    "drupal/gin_lb": "1.0.0-rc3",
    "drupal/hide_revision_field": "2.3.0",
    "drupal/honeypot": "2.1.2",
    "drupal/image_widget_crop": "2.4.0",
    "drupal/improve_line_breaks_filter": "1.5.0",
    "drupal/inline_entity_form": "1.0.0-rc15",
    "drupal/layout_builder_browser": "1.5.0",
    "drupal/layout_builder_iframe_modal": "1.3.0",
    "drupal/layout_builder_lock": "1.2.0",
    "drupal/layout_builder_restrictions": "2.17.0",
    "drupal/layout_builder_restrictions_by_role": "1.0.0-alpha5",
    "drupal/libraries": "4.0.2",
    "drupal/linkit": "6.0.0-rc1",
    "drupal/mailchimp_transactional": "1.0.1",
    "drupal/mailsystem": "4.4.0",
    "drupal/markup": "2.0.0-beta6",
    "drupal/maxlength": "2.1.1",
    "drupal/media_library_edit": "3.0.2",
    "drupal/media_library_form_element": "2.0.6",
    "drupal/menu_admin_per_menu": "1.5.0",
    "drupal/menu_breadcrumb": "2.0.0-alpha0",
    "drupal/metatag": "1.23.0",
    "drupal/migrate_plus": "6.0.1",
    "drupal/migrate_tools": "6.0.1",
    "drupal/node_revision_delete": "1.0.0-rc6",
    "drupal/override_node_options": "2.7.0",
    "drupal/pantheon_advanced_page_cache": "2.1.2",
    "drupal/paragraphs": "1.15",
    "drupal/paragraphs_features": "2.0.0-beta2",
    "drupal/pathauto": "1.11.0",
    "drupal/publishcontent": "1.6.0",
    "drupal/quick_node_clone": "1.16.0",
    "drupal/recaptcha": "3.2.0",
    "drupal/recaptcha_v3": "1.8.0",
    "drupal/redirect": "1.8.0",
    "drupal/search_api": "1.29.0",
    "drupal/search_api_exclude": "2.0.2",
    "drupal/section_library": "1.1.0",
    "drupal/simple_sitemap": "4.1.4",
    "drupal/smart_date": "3.7.2",
    "drupal/twig_tweak": "3.2.1",
    "drupal/upgrade_status": "4.0.0",
    "drupal/webform": "6.2.0-beta5",
    "drupal/wingsuit_companion": "2.1.0",
    "yalesites-org/atomic": "1.11.0",
    "yalesites-org/yale_cas": "1.0.4"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true
  },
  "extra": {
    "enable-patching": true,
    "composer-exit-on-patch-failure": true,
    "patchLevel": {
      "drupal/core": "-p2"
    },
    "patches": {
      "drupal/layout_paragraphs": {
        "save close tweaks": "https://git.drupalcode.org/project/layout_paragraphs/-/merge_requests/80.patch"
      },
      "drupal/paragraphs": {
        "hide remove button": "https://www.drupal.org/files/issues/2020-05-13/hide_field_required_paragraphs_remove_button_1.patch"
      },
      "drupal/core": {
        "plural results summary https://www.drupal.org/project/drupal/issues/2888320": "https://www.drupal.org/files/issues/2021-12-15/2888320-78.patch"
      },
      "drupal/entity_redirect": {
        "fix layout route https://www.drupal.org/project/entity_redirect/issues/3352265": "https://git.drupalcode.org/project/entity_redirect/-/merge_requests/6.patch"
      },
      "drupal/layout_builder_restrictions_by_role": {
        "Fix user 1 https://www.drupal.org/project/layout_builder_restrictions_by_role/issues/3298638": "https://www.drupal.org/files/issues/2022-07-28/3298638--layout_builder_restrictions_by_role--user-1-exception-8.patch"
      },
      "drupal/layout_builder_browser": {
        "close modal on submit https://www.drupal.org/project/layout_builder_browser/issues/3352754": "https://www.drupal.org/files/issues/2023-04-19/layout_builder_browser-modal_does_not_close_on_submit-3352754-2.patch"
      },
      "drupal/gin_lb": {
        "fix missing file field https://www.drupal.org/project/gin_lb/issues/3349745": "https://www.drupal.org/files/issues/2023-03-23/3349745-8-claro-preprocess-file-fields.patch"
      }
    }
  }
}
